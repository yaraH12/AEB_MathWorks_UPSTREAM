system requirements UpStreamReq14DOF for  aebsystem::VD14DOFVariant::VehicleDynamics14DOF.ImplForUpStream[ 
	description "These are requirements for the Dynamic Vehicle model in the development phase"
	
	
		
		requirement R1FeatureControlPedal: "VDM-UPSTREAM-FID-FUN-01"[
		description "The model must control the braking pedal"
		description "Evidence Solution (Verification Activity): Check the features and subsystems covered by the model"
		rationale " To prevent collision when obstacle is detected"
		category  Fidelity.FunctionsCoverage
		see goal AEBSystemGoals.g5
	]
	
	requirement R2FeatureCalcTTC: "VDM-UPSTREAM-FID-FUN-02"[
		val MinTTC = 5 
		description "The model must calculate the Time to collision"
		description "Evidence Solution (Verification Activity): Check the features and subsystems covered by the model"
		rationale " To stop the vehicle if TTC is equal to MinTTC" 
		category  Fidelity.FunctionsCoverage
		see goal AEBSystemGoals.g5
	]
	
	requirement R3Validity:"VDM-UPSTREAM-VAL-01"[
		val ExpectedConcordance = 90.0 //%
